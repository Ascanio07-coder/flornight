# ============================================================
# Frontend (Vite) - esposte al client, prefissate VITE_*
# ============================================================
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# Backend (Vercel Functions) - SOLO lato server, mai esporre
# ============================================================

# Stripe (dashboard -> Developers -> API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase Service Role: necessario al webhook per scrivere is_paid/qr_code
# bypassando le RLS. NON prefissare con VITE_ e non usarlo lato client.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
